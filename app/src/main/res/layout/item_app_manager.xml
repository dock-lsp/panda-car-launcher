<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="@dimen/spacing_sm"
    android:layout_marginBottom="1dp"
    android:background="@drawable/bg_card">

    <!-- 应用图标 -->
    <ImageView
        android:id="@+id/iv_app_icon"
        android:layout_width="@dimen/app_icon_size"
        android:layout_height="@dimen/app_icon_size"
        android:src="@drawable/ic_apps"
        android:scaleType="fitCenter" />

    <!-- 应用信息 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_md">

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="应用名称"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_normal"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_app_package"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="com.example.app"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_size_micro"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- 共存版标签 -->
        <TextView
            android:id="@+id/tv_dual_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="共存版"
            android:textColor="@color/primary"
            android:textSize="@dimen/text_size_micro"
            android:background="@drawable/bg_icon_cyan"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 添加到桌面按钮 -->
    <ImageView
        android:id="@+id/btn_add_to_desktop"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_add"
        android:padding="6dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="添加到桌面" />

    <!-- 卸载按钮 -->
    <ImageView
        android:id="@+id/btn_uninstall"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="@dimen/spacing_sm"
        android:src="@drawable/ic_delete"
        android:padding="6dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="卸载" />

</LinearLayout>
