<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 顶部标题栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btn_back"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="应用管理"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_large"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- 搜索栏 -->
    <EditText
        android:id="@+id/et_search"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:background="@drawable/bg_card"
        android:hint="搜索应用..."
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_normal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:singleLine="true"
        android:inputType="text" />

    <!-- 分类标签 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_sm">

        <LinearLayout
            android:id="@+id/category_tabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_all"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:text="全部"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_size_medium"
                android:background="@drawable/bg_icon_cyan" />

            <TextView
                android:id="@+id/tab_navigation"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:layout_marginStart="@dimen/spacing_sm"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:text="导航"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_medium"
                android:background="@drawable/bg_card" />

            <TextView
                android:id="@+id/tab_music"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:layout_marginStart="@dimen/spacing_sm"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:text="音乐"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_medium"
                android:background="@drawable/bg_card" />

            <TextView
                android:id="@+id/tab_video"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:layout_marginStart="@dimen/spacing_sm"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:text="视频"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_medium"
                android:background="@drawable/bg_card" />

            <TextView
                android:id="@+id/tab_tool"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:layout_marginStart="@dimen/spacing_sm"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:text="工具"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_medium"
                android:background="@drawable/bg_card" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- 应用列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_app_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md" />

</LinearLayout>
