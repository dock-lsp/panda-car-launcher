<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_plugin_card"
    android:orientation="vertical"
    android:padding="10dp"
    android:elevation="8dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_navigation"
            android:tint="#00CED1" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="导航"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/float_nav_close"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_close"
            android:padding="2dp" />

    </LinearLayout>

    <!-- 状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_navigation"
            android:tint="#4000CED1" />

        <TextView
            android:id="@+id/float_nav_remain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="导航运行中"
            android:textColor="#00CED1"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/float_nav_road"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="点击打开导航"
            android:textColor="#80FFFFFF"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- 打开按钮 -->
    <Button
        android:id="@+id/float_nav_open"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:text="打开导航"
        android:textSize="12sp"
        android:backgroundTint="#00CED1"
        android:textColor="#FFFFFF" />

</LinearLayout>
