<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <!-- 壁纸层 -->
    <ImageView
        android:id="@+id/iv_wallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- 主内容层 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@android:color/transparent">

    <!-- 顶部状态栏 -->
    <include
        android:id="@+id/status_bar"
        layout="@layout/layout_status_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/status_bar_height" />

    <!-- 主内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="@dimen/card_margin"
        android:paddingEnd="@dimen/card_margin"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm">

        <!-- 顶部：导航卡片 -->
        <include
            android:id="@+id/card_navigation"
            layout="@layout/layout_card_map"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <!-- 中间：应用网格 -->
        <include
            android:id="@+id/app_grid_container"
            layout="@layout/layout_app_grid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <!-- 底部：音乐卡片 -->
        <include
            android:id="@+id/card_music"
            layout="@layout/layout_card_music"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- 底部导航栏 -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height" />

    </LinearLayout>

</FrameLayout>
