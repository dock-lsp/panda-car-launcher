<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <!-- 壁纸层 -->
    <ImageView
        android:id="@+id/iv_wallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- 主内容层 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@android:color/transparent">

    <!-- 顶部状态栏 -->
    <include
        android:id="@+id/status_bar"
        layout="@layout/layout_status_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/status_bar_height" />

    <!-- 主内容区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="@dimen/card_margin"
        android:paddingEnd="@dimen/card_margin"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm">

        <!-- 应用网格（默认显示） -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_app_grid"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 导航插件容器（默认隐藏） -->
        <FrameLayout
            android:id="@+id/plugin_navigation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@drawable/bg_card">

            <!-- 右上角切换导航按钮 -->
            <ImageView
                android:id="@+id/btn_switch_nav"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="end"
                android:layout_margin="8dp"
                android:src="@drawable/ic_map_switch"
                android:padding="4dp"
                android:background="@drawable/bg_control_btn"
                android:elevation="4dp" />

            <!-- 导航 WebView -->
            <WebView
                android:id="@+id/webview_navigation"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="4dp" />

            <!-- 加载状态 -->
            <LinearLayout
                android:id="@+id/nav_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_loading_card"
                android:padding="24dp">

                <ProgressBar
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:indeterminateTint="#00CED1" />

                <TextView
                    android:id="@+id/nav_loading_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="正在加载导航..."
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

            </LinearLayout>

        </FrameLayout>

        <!-- 音乐插件容器（默认隐藏） -->
        <LinearLayout
            android:id="@+id/plugin_music"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/card_padding">

            <!-- 顶部：标题 + 切换按钮 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="正在播放"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_medium"
                    android:textStyle="bold"
                    android:layout_centerVertical="true" />

                <ImageView
                    android:id="@+id/btn_switch_music"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_music_switch"
                    android:padding="4dp"
                    android:background="@drawable/bg_control_btn" />

            </RelativeLayout>

            <!-- 歌曲信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/plugin_tv_song"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="未在播放"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/plugin_tv_artist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="选择音乐应用开始播放"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_normal" />

                <!-- 歌词区域 -->
                <TextView
                    android:id="@+id/plugin_tv_lyrics"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:lineSpacingExtra="8dp"
                    android:maxLines="6"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- 播放控制 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/plugin_btn_prev"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_skip_prev"
                    android:padding="8dp"
                    android:background="@drawable/bg_control_btn" />

                <ImageView
                    android:id="@+id/plugin_btn_play"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_play"
                    android:background="@drawable/bg_icon_cyan"
                    android:padding="12dp" />

                <ImageView
                    android:id="@+id/plugin_btn_next"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_skip_next"
                    android:padding="8dp"
                    android:background="@drawable/bg_control_btn" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- 底部导航栏 -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height" />

    </LinearLayout>

</FrameLayout>
