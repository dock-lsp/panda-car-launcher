<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_floating_card"
    android:orientation="vertical"
    android:padding="12dp"
    android:elevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_music"
            android:tint="#00CED1" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="正在播放"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/music_card_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:padding="2dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/music_card_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未在播放"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center" />

        <TextView
            android:id="@+id/music_card_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=""
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="8dp">

        <ImageView
            android:id="@+id/music_card_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_skip_prev"
            android:padding="8dp"
            android:background="@drawable/bg_control_btn" />

        <ImageView
            android:id="@+id/music_card_play"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/bg_icon_cyan"
            android:padding="11dp" />

        <ImageView
            android:id="@+id/music_card_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_skip_next"
            android:padding="8dp"
            android:background="@drawable/bg_control_btn" />

    </LinearLayout>

</LinearLayout>
