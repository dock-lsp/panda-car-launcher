<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部标题栏 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/btn_back"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="系统设置"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_large"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- 设备存储信息卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/card_margin"
            android:layout_marginEnd="@dimen/card_margin"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/card_glass"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <!-- 存储标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设备存储"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_normal"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_file"
                    android:drawablePadding="@dimen/spacing_sm"
                    android:gravity="center_vertical" />

                <!-- 存储进度条 -->
                <ProgressBar
                    android:id="@+id/storage_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="@color/primary"
                    android:progressBackgroundTint="@color/surface_light" />

                <!-- 存储详情 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_total_storage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_normal"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="总存储"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_micro" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/text_hint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_used_storage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/accent_orange"
                            android:textSize="@dimen/text_size_normal"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已使用"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_micro" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/text_hint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_available_storage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/accent_green"
                            android:textSize="@dimen/text_size_normal"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="可用空间"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_micro" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 悬浮球开关卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/card_margin"
            android:layout_marginEnd="@dimen/card_margin"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/card_glass"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_icon_cyan" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_settings"
                        android:contentDescription="悬浮球" />

                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="悬浮球"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_normal" />

                <Switch
                    android:id="@+id/switch_float_ball"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/primary"
                    android:trackTint="@color/surface_light" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 设置列表卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/card_margin"
            android:layout_marginEnd="@dimen/card_margin"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/card_glass"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:id="@+id/setting_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 悬浮球设置 -->
                <include
                    android:id="@+id/item_float_ball_setting"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 视频播放器 -->
                <include
                    android:id="@+id/item_video_player"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- WiFi设置 -->
                <include
                    android:id="@+id/item_wifi"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 蓝牙设置 -->
                <include
                    android:id="@+id/item_bluetooth"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 显示设置 -->
                <include
                    android:id="@+id/item_display"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 声音设置 -->
                <include
                    android:id="@+id/item_sound"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 应用管理 -->
                <include
                    android:id="@+id/item_app_manager"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 存储设置 -->
                <include
                    android:id="@+id/item_storage"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 位置设置 -->
                <include
                    android:id="@+id/item_location"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 主题切换 -->
                <include
                    android:id="@+id/item_theme"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 壁纸设置 -->
                <include
                    android:id="@+id/item_wallpaper"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 蓝牙音乐 -->
                <include
                    android:id="@+id/item_bluetooth_music"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 文件管理器 -->
                <include
                    android:id="@+id/item_file_manager"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 小组件 -->
                <include
                    android:id="@+id/item_widgets"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 应用市场 -->
                <include
                    android:id="@+id/item_app_market"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 手机投屏 -->
                <include
                    android:id="@+id/item_screen_cast"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 一键清理 -->
                <include
                    android:id="@+id/item_clean_background"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 画中画模式 -->
                <include
                    android:id="@+id/item_pip"
                    layout="@layout/item_setting" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="68dp" />

                <!-- 关于我们 -->
                <include
                    android:id="@+id/item_about"
                    layout="@layout/item_setting" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 底部留白 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_lg" />

    </LinearLayout>

</ScrollView>
