<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="12dp">

    <!-- 菜单标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="快捷菜单"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_small"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp" />

    <!-- 功能按钮网格 -->
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2">

        <!-- 桌面 -->
        <LinearLayout
            android:id="@+id/btn_menu_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_home"
                android:background="@drawable/bg_icon_cyan"
                android:padding="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="桌面"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_micro"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 返回 -->
        <LinearLayout
            android:id="@+id/btn_menu_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/bg_icon_blue"
                android:padding="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="返回"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_micro"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 最近任务 -->
        <LinearLayout
            android:id="@+id/btn_menu_recent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_apps"
                android:background="@drawable/bg_icon_green"
                android:padding="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="任务"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_micro"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 音乐 -->
        <LinearLayout
            android:id="@+id/btn_menu_music"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_music"
                android:background="@drawable/bg_icon_orange"
                android:padding="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="音乐"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_micro"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 导航 -->
        <LinearLayout
            android:id="@+id/btn_menu_nav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_navigation"
                android:background="@drawable/bg_icon_purple"
                android:padding="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="导航"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_micro"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 关闭 -->
        <LinearLayout
            android:id="@+id/btn_menu_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/bg_icon_red"
                android:padding="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="关闭"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_micro"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </GridLayout>

</LinearLayout>
