<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_floating_card"
    android:orientation="vertical"
    android:padding="12dp"
    android:elevation="8dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_navigation"
            android:tint="#00CED1" />

        <TextView
            android:id="@+id/floating_nav_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="导航"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- 缩放按钮 -->
        <ImageView
            android:id="@+id/floating_nav_zoom_in"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_plus"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <ImageView
            android:id="@+id/floating_nav_zoom_out"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_minus"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <ImageView
            android:id="@+id/floating_nav_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_close"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- 导航状态 -->
    <TextView
        android:id="@+id/floating_nav_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="点击打开导航"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <!-- 控制按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/floating_nav_open"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="打开导航"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@drawable/bg_icon_cyan" />

        <Button
            android:id="@+id/floating_nav_close_nav"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="关闭导航"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@drawable/bg_control_btn" />

    </LinearLayout>

</LinearLayout>
