<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 壁纸层 -->
    <ImageView
        android:id="@+id/iv_wallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- 主内容层 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部状态栏 -->
        <include
            android:id="@+id/status_bar"
            layout="@layout/layout_status_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/status_bar_height" />

        <!-- 中间区域：插件容器 + 应用网格 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- 应用网格（默认显示） -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_app_grid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/card_margin"
                android:paddingEnd="@dimen/card_margin"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm" />

            <!-- 左侧：导航插件容器（默认隐藏） -->
            <LinearLayout
                android:id="@+id/nav_plugin_container"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_plugin_card"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone"
                android:elevation="4dp">

                <!-- 导航标题栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_navigation"
                        android:tint="#00CED1" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="导航"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/nav_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="高德 ▼"
                        android:textColor="#00CED1"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- 导航状态 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_navigation"
                        android:tint="#4000CED1" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/nav_remain"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="导航运行中"
                            android:textColor="#00CED1"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/nav_road"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="点击打开导航"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- 右侧：音乐插件容器（默认隐藏） -->
            <LinearLayout
                android:id="@+id/music_plugin_container"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_plugin_card"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone"
                android:elevation="4dp">

                <!-- 音乐标题栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_music"
                        android:tint="#00CED1" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="正在播放"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- 歌曲信息 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/music_album"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_music"
                        android:background="@drawable/bg_icon_cyan"
                        android:padding="10dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/music_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未在播放"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/music_artist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text=""
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 播放控制 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/music_prev"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_skip_prev"
                        android:padding="6dp"
                        android:background="@drawable/bg_control_btn" />

                    <ImageView
                        android:id="@+id/music_play"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_play"
                        android:background="@drawable/bg_icon_cyan"
                        android:padding="9dp" />

                    <ImageView
                        android:id="@+id/music_next"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_skip_next"
                        android:padding="6dp"
                        android:background="@drawable/bg_control_btn" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- 底部导航栏 -->
        <include
            android:id="@+id/bottom_nav"
            layout="@layout/layout_bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_height" />

    </LinearLayout>

</FrameLayout>
