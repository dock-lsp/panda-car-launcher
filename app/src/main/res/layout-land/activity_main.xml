<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 壁纸层 -->
    <ImageView
        android:id="@+id/iv_wallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- 主内容层 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部状态栏 -->
        <include
            android:id="@+id/status_bar"
            layout="@layout/layout_status_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/status_bar_height" />

        <!-- 中间区域：插件容器 -->
        <FrameLayout
            android:id="@+id/plugin_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- 应用网格（默认显示） -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_app_grid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/card_margin"
                android:paddingEnd="@dimen/card_margin"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm" />

            <!-- 导航插件（默认隐藏） -->
            <FrameLayout
                android:id="@+id/nav_plugin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:background="#E61A1A2E">

                <!-- 导航内容区域 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 顶部标题栏 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_navigation"
                            android:tint="#00CED1" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="导航"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/nav_plugin_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="高德 ▼"
                            android:textColor="#00CED1"
                            android:textSize="13sp"
                            android:padding="4dp" />

                        <ImageView
                            android:id="@+id/nav_plugin_close"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_close"
                            android:padding="4dp" />

                    </LinearLayout>

                    <!-- 导航状态 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_navigation"
                            android:tint="#3000CED1" />

                        <TextView
                            android:id="@+id/nav_plugin_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="导航运行中"
                            android:textColor="#00CED1"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="点击打开导航应用"
                            android:textColor="#80FFFFFF"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <!-- 打开导航按钮 -->
                    <Button
                        android:id="@+id/nav_plugin_open"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="打开导航"
                        android:textSize="16sp"
                        android:backgroundTint="#00CED1"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

            </FrameLayout>

            <!-- 音乐插件（默认隐藏） -->
            <FrameLayout
                android:id="@+id/music_plugin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:background="#E61A1A2E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 顶部标题栏 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_music"
                            android:tint="#00CED1" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="正在播放"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/music_plugin_close"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_close"
                            android:padding="4dp" />

                    </LinearLayout>

                    <!-- 歌曲信息 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/music_plugin_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未在播放"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/music_plugin_artist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text=""
                            android:textColor="#80FFFFFF"
                            android:textSize="16sp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                    <!-- 播放控制 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingTop="16dp"
                        android:paddingBottom="8dp">

                        <ImageView
                            android:id="@+id/music_plugin_prev"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:src="@drawable/ic_skip_prev"
                            android:padding="12dp"
                            android:background="@drawable/bg_control_btn" />

                        <ImageView
                            android:id="@+id/music_plugin_play"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginStart="24dp"
                            android:layout_marginEnd="24dp"
                            android:src="@drawable/ic_play"
                            android:background="@drawable/bg_icon_cyan"
                            android:padding="16dp" />

                        <ImageView
                            android:id="@+id/music_plugin_next"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:src="@drawable/ic_skip_next"
                            android:padding="12dp"
                            android:background="@drawable/bg_control_btn" />

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

        </FrameLayout>

        <!-- 底部导航栏 -->
        <include
            android:id="@+id/bottom_nav"
            layout="@layout/layout_bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_height" />

    </LinearLayout>

</FrameLayout>
