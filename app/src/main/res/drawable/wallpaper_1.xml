<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 底层渐变 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0D1642"
                android:endColor="#1A237E"
                android:angle="135" />
        </shape>
    </item>
    <!-- 装饰圆 -->
    <item
        android:left="-100dp"
        android:top="-100dp"
        android:width="400dp"
        android:height="400dp">
        <shape android:shape="oval">
            <solid android:color="#150A3E" />
        </shape>
    </item>
    <item
        android:right="-80dp"
        android:bottom="-80dp"
        android:width="300dp"
        android:height="300dp">
        <shape android:shape="oval">
            <solid android:color="#0A2A5E" />
        </shape>
    </item>
</layer-list>
